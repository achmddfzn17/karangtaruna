// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ===== AUTH MODELS (NextAuth) =====

enum Role {
  SUPER_ADMIN
  ADMIN
  ANGGOTA
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(ANGGOTA)
  accounts      Account[]
  sessions      Session[]
  anggota       Anggota?
  admin         Admin?
  susResponses  SusResponse[]
  notifications Notification[]
  aspirasi      Aspirasi[]
  votes         Vote[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ===== ADMIN =====

model Admin {
  id       String  @id @default(cuid())
  userId   String  @unique
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  nip      String? @unique
  phone    String?
  jabatan  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admins")
}

// ===== ANGGOTA =====

enum JenisKelamin {
  LAKI_LAKI
  PEREMPUAN
}

enum StatusAnggota {
  AKTIF
  NON_AKTIF
  ALUMNI
}

model Anggota {
  id            String        @id @default(cuid())
  userId        String?       @unique
  user          User?         @relation(fields: [userId], references: [id])
  namaLengkap   String
  nik           String        @unique
  tempatLahir   String?
  tanggalLahir  DateTime?
  jenisKelamin  JenisKelamin
  alamat        String?       @db.Text
  noHp          String?
  email         String?
  foto          String?
  pekerjaan     String?
  pendidikan    String?
  status        StatusAnggota @default(AKTIF)
  tanggalGabung DateTime      @default(now())
  kegiatan      AnggotaKegiatan[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("anggota")
}

// ===== KEGIATAN =====

enum JenisKegiatan {
  SOSIAL
  PENDIDIKAN
  EKONOMI
  OLAHRAGA
  SENI_BUDAYA
  LAINNYA
}

enum StatusKegiatan {
  UPCOMING
  ONGOING
  SELESAI
  DIBATALKAN
}

model Kegiatan {
  id             String         @id @default(cuid())
  nama           String
  deskripsi      String?        @db.Text
  jenis          JenisKegiatan
  tanggalMulai   DateTime
  tanggalSelesai DateTime?
  lokasi         String?
  anggaran       Float?
  thumbnail      String?
  status         StatusKegiatan @default(UPCOMING)
  peserta        AnggotaKegiatan[]
  galeri         GaleriItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("kegiatan")
}

model AnggotaKegiatan {
  id         String   @id @default(cuid())
  anggotaId  String
  kegiatanId String
  anggota    Anggota  @relation(fields: [anggotaId], references: [id], onDelete: Cascade)
  kegiatan   Kegiatan @relation(fields: [kegiatanId], references: [id], onDelete: Cascade)
  hadir      Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@unique([anggotaId, kegiatanId])
  @@map("anggota_kegiatan")
}

// ===== PROGRAM =====

model Program {
  id        String  @id @default(cuid())
  nama      String
  deskripsi String? @db.Text
  thumbnail String?
  icon      String?
  status    Boolean @default(true)
  urutan    Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("program")
}

// ===== KONTEN =====

enum StatusPublish {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Berita {
  id          String        @id @default(cuid())
  judul       String
  slug        String        @unique
  isi         String        @db.Text
  ringkasan   String?       @db.Text
  thumbnail   String?
  tags        String[]
  kategori    String?
  status      StatusPublish @default(DRAFT)
  publishedAt DateTime?
  viewCount   Int           @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, publishedAt(sort: Desc)])
  @@map("berita")
}

model Artikel {
  id          String        @id @default(cuid())
  judul       String
  slug        String        @unique
  isi         String        @db.Text
  ringkasan   String?       @db.Text
  thumbnail   String?
  tags        String[]
  kategori    String?
  status      StatusPublish @default(DRAFT)
  publishedAt DateTime?
  viewCount   Int           @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, publishedAt(sort: Desc)])
  @@map("artikel")
}

// ===== GALERI =====

enum GaleriType {
  FOTO
  VIDEO
}

model GaleriItem {
  id         String     @id @default(cuid())
  judul      String
  deskripsi  String?
  url        String
  type       GaleriType @default(FOTO)
  kegiatanId String?
  kegiatan   Kegiatan?  @relation(fields: [kegiatanId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("galeri_item")
}

// ===== KEUANGAN =====

enum JenisTransaksi {
  MASUK
  KELUAR
}

model KategoriTransaksi {
  id         String         @id @default(cuid())
  nama       String
  jenis      JenisTransaksi
  keterangan String?
  transaksi  TransaksiKeuangan[]

  createdAt DateTime @default(now())

  @@map("kategori_transaksi")
}

model TransaksiKeuangan {
  id         String            @id @default(cuid())
  tanggal    DateTime
  keterangan String
  jumlah     Float
  jenis      JenisTransaksi
  kategoriId String?
  kategori   KategoriTransaksi? @relation(fields: [kategoriId], references: [id])
  bukti      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("transaksi_keuangan")
}

// ===== SUS =====

model SusResponse {
  id        String  @id @default(cuid())
  userId    String?
  user      User?   @relation(fields: [userId], references: [id])
  responden String?
  q1        Int
  q2        Int
  q3        Int
  q4        Int
  q5        Int
  q6        Int
  q7        Int
  q8        Int
  q9        Int
  q10       Int
  score     Float
  kategori  String

  createdAt DateTime @default(now())

  @@map("sus_responses")
}

// ===== NOTIFICATIONS =====

model Notification {
  id      String  @id @default(cuid())
  title   String
  message String
  type    String  @default("info")
  isRead  Boolean @default(false)
  userId  String?
  user    User?   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@map("notifications")
}

// ===== ASPIRASI =====

enum StatusAspirasi {
  PENDING
  DIPROSES
  SELESAI
  DITOLAK
}

model Aspirasi {
  id        String         @id @default(cuid())
  userId    String?
  user      User?          @relation(fields: [userId], references: [id])
  nama      String?
  judul     String
  pesan     String         @db.Text
  kategori  String?
  status    StatusAspirasi @default(PENDING)
  balasan   String?        @db.Text
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@map("aspirasi")
}

// ===== POLLING (E-Voting) =====

model Polling {
  id          String   @id @default(cuid())
  judul       String
  deskripsi   String?  @db.Text
  isActive    Boolean  @default(true)
  expiresAt   DateTime?
  options     PollingOption[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("polling")
}

model PollingOption {
  id        String   @id @default(cuid())
  pollingId String
  polling   Polling  @relation(fields: [pollingId], references: [id], onDelete: Cascade)
  label     String
  votes     Vote[]
  
  @@map("polling_options")
}

model Vote {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  pollingId String
  optionId  String
  option    PollingOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, pollingId])
  @@map("votes")
}
